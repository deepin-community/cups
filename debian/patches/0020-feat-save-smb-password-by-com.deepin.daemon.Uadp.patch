diff --git a/scheduler/job.c b/scheduler/job.c
index 491277531..140f0e459 100644
--- a/scheduler/job.c
+++ b/scheduler/job.c
@@ -1988,14 +1988,100 @@ cupsdLoadJob(cupsd_job_t *job)		/* I - Job */
 
   if (job->state_value < IPP_JOB_STOPPED)
   {
-    snprintf(jobfile, sizeof(jobfile), "%s/a%05d", RequestRoot, job->id);
-
     for (i = 0;
 	 i < (int)(sizeof(job->auth_env) / sizeof(job->auth_env[0]));
 	 i ++)
       cupsdClearString(job->auth_env + i);
     cupsdClearString(&job->auth_uid);
 
+    if (job->printer && job->printer->device_uri)
+    {
+      unsigned char	*auth_data = NULL;/* Decrypted auth data from uadp */
+      size_t		auth_len;	/* Length of auth data */
+
+
+      snprintf(jobfile, sizeof(jobfile), "auth/job/%05d", job->id);
+
+      if (cupsd_uadp_retrieve(jobfile, &auth_data, &auth_len) == 0 && auth_data)
+      {
+       /*
+        * Parse the serialized auth buffer (same format as the file)...
+        */
+
+	char	line[65536],		/* Line from buffer */
+		*value,			/* Value from line */
+		*bufptr,		/* Current position in buffer */
+		*next;			/* Next line pointer */
+
+
+	bufptr = (char *)auth_data;
+	bufptr[auth_len] = '\0';
+
+	if ((next = strchr(bufptr, '\n')) != NULL)
+	{
+	  *next++ = '\0';
+
+	  if (!strcmp(bufptr, "CUPSD-AUTH-V3"))
+	  {
+	    i = 0;
+
+	    while ((value = strchr(next, ' ')) != NULL && *next)
+	    {
+	     /*
+	      * Split key and value...
+	      */
+
+	      strlcpy(line, next, (size_t)(value - next + 1));
+
+	     /*
+	      * Find end of line and advance...
+	      */
+
+	      if ((next = strchr(value, '\n')) != NULL)
+		*next++ = '\0';
+	      else
+		next = value + strlen(value);
+
+	     /*
+	      * Assign environment variables...
+	      */
+
+	      if (!strcmp(line, "uid"))
+	      {
+		cupsdSetStringf(&job->auth_uid, "AUTH_UID=%s", value + 1);
+		continue;
+	      }
+	      else if (i >= (int)(sizeof(job->auth_env) / sizeof(job->auth_env[0])))
+		break;
+
+	      if (!strcmp(line, "username"))
+		cupsdSetStringf(job->auth_env + i, "AUTH_USERNAME=%s", value + 1);
+	      else if (!strcmp(line, "domain"))
+		cupsdSetStringf(job->auth_env + i, "AUTH_DOMAIN=%s", value + 1);
+	      else if (!strcmp(line, "password"))
+		cupsdSetStringf(job->auth_env + i, "AUTH_PASSWORD=%s", value + 1);
+	      else if (!strcmp(line, "negotiate"))
+		cupsdSetStringf(job->auth_env + i, "AUTH_NEGOTIATE=%s", value + 1);
+	      else
+		continue;
+
+	      i ++;
+	    }
+	  }
+	}
+
+	cupsd_uadp_free(auth_data);
+	goto auth_loaded;
+      }
+    }
+
+   /*
+    * File-based loading for non-SMB printers, and as fallback when uadp
+    * is unavailable for SMB printers.
+    */
+
+    snprintf(jobfile, sizeof(jobfile), "%s/a%05d", RequestRoot, job->id);
+
     if ((fp = cupsFileOpen(jobfile, "r")) != NULL)
     {
       int	bytes,			/* Size of auth data */
@@ -2052,6 +2138,8 @@ cupsdLoadJob(cupsd_job_t *job)		/* I - Job */
     }
   }
 
+  auth_loaded:
+
   job->access_time = time(NULL);
   return (1);
 
@@ -2704,9 +2792,18 @@ cupsdSetJobState(
 #endif /* __APPLE__ */
 
        /*
-	* Remove any authentication data...
+	* Remove any Uadp-backed authentication data.
+	* For completed or canceled jobs the password is no longer needed.
+	* For aborted (failed) jobs we keep it so the user can retry.
 	*/
 
+	if (job->printer && job->printer->device_uri &&
+	    job->state_value != IPP_JOB_ABORTED)
+	{
+	  snprintf(filename, sizeof(filename), "auth/job/%05d", job->id);
+	  cupsd_uadp_delete(filename);
+	}
+
 	snprintf(filename, sizeof(filename), "%s/a%05d", RequestRoot, job->id);
 	if (cupsdRemoveFile(filename) && errno != ENOENT)
 	  cupsdLogMessage(CUPSD_LOG_ERROR,
diff --git a/scheduler/printers.c b/scheduler/printers.c
index 2fbdaad5b..ae3d9fc91 100644
--- a/scheduler/printers.c
+++ b/scheduler/printers.c
@@ -756,6 +756,19 @@ cupsdDeletePrinter(
 
   cupsdLogMessage(CUPSD_LOG_DEBUG2,
                   "cupsdDeletePrinter: Removing %s from Printers", p->name);
+
+ /*
+  * Clean up any uadp-stored credentials for this printer...
+  */
+
+  if (p->device_uri && !strncmp(p->device_uri, "smb", 3))
+  {
+    char	tpm_key[256];		/* uadp storage key */
+
+
+    snprintf(tpm_key, sizeof(tpm_key), "printer-cred/%s", p->name);
+    cupsd_uadp_delete(tpm_key);
+  }
   cupsArrayRemove(Printers, p);
 
  /*
@@ -1132,7 +1145,64 @@ cupsdLoadAllPrinters(void)
     else if (!_cups_strcasecmp(line, "DeviceURI"))
     {
       if (value)
-	cupsdSetDeviceURI(p, value);
+	{
+		cupsdSetDeviceURI(p, value);
+
+		/*
+		 * For SMB printers with a sanitized URI (no embedded credentials),
+		 * try to retrieve credentials from uadp and reconstruct the full URI...
+		 */
+
+		if (p->device_uri && !strncmp(p->device_uri, "smb", 3))
+		{
+		  unsigned char	*tpm_data = NULL;	/* uadp data */
+		  size_t	tpm_len;		/* uadp data length */
+		  char		tpm_key[256];		/* uadp storage key */
+		  char		full_uri[1024];		/* Full URI buffer */
+		  char		*at_pos;		/* Position to insert @ */
+
+
+		  snprintf(tpm_key, sizeof(tpm_key), "printer-cred/%s", p->name);
+
+		  if (cupsd_uadp_safe_key_name(p->name) &&
+		      cupsd_uadp_retrieve(tpm_key, &tpm_data, &tpm_len) == 0 &&
+		      tpm_data && tpm_len > 0)
+		  {
+		   /*
+		    * Parse the credential buffer (format: user\\npass).
+		    * Reconstruct full URI: smb://user:pass@host/path
+		    */
+
+		    char	*newline;		/* Separator */
+		    char	*user_val = (char *)tpm_data;
+		    char	*pass_val = "";
+
+
+		    if ((newline = strchr(user_val, '\n')) != NULL)
+		    {
+		      *newline++ = '\0';
+		      pass_val = newline;
+		    }
+
+		   /*
+		    * Find the position to insert credentials in the sanitized URI.
+		    * Format: smb://host/path -> smb://user:pass@host/path
+		    */
+
+		    if ((at_pos = strstr(p->device_uri, "//")) != NULL)
+		    {
+		      at_pos += 2;	/* Skip past // */
+		      snprintf(full_uri, sizeof(full_uri),
+		               "%.*s%s:%s@%s",
+		               (int)(at_pos - p->device_uri), p->device_uri,
+		               user_val, pass_val, at_pos);
+		      cupsdSetString(&(p->device_uri), full_uri);
+		    }
+
+		    cupsd_uadp_free(tpm_data);
+		  }
+		}
+	  }
       else
 	cupsdLogMessage(CUPSD_LOG_ERROR,
 	                "Syntax error on line %d of printers.conf.", linenum);
@@ -1614,7 +1684,146 @@ cupsdSaveAllPrinters(void)
     if (printer->organizational_unit)
       cupsFilePutConf(fp, "OrganizationalUnit", printer->organizational_unit);
 
-    cupsFilePutConf(fp, "DeviceURI", printer->device_uri);
+
+    if (printer->device_uri && !strncmp(printer->device_uri, "smb", 3))
+    {
+      char		uri_buf[1024];	/* Sanitized URI buffer */
+      char		*start,		/* Start after scheme:// */
+      			*at,		/* @ sign */
+      			*slash,		/* First / after host */
+      			*colon;		/* : separator in credentials */
+      size_t		ulen;		/* Length of credentials */
+      char		tpm_key[256];	/* uadp storage key */
+
+
+      strlcpy(uri_buf, printer->device_uri, sizeof(uri_buf));
+
+      if ((start = strchr(uri_buf, ':')) != NULL)
+      {
+        for (start ++; *start == '/'; start ++);
+
+        if ((slash = strchr(start, '/')) == NULL)
+          slash = start + strlen(start);
+
+        if ((at = strchr(start, '@')) != NULL && at < slash)
+        {
+         /*
+          * Found embedded credentials in SMB URI (smb://user:pass@host/path).
+          * Store via uadp and write sanitized URI to config.
+          */
+
+          unsigned char	*tpm_data = NULL;/* Existing uadp data */
+          size_t	tpm_len;	/* Length of existing uadp data */
+          char		cred_buf[1280];	/* user\npass buffer */
+          size_t	cred_len;	/* Length of cred buffer */
+
+
+          *at = '\0';		/* Temporarily null-terminate at @ */
+
+         /*
+          * Extract username and password...
+          */
+
+          char user[256], pass[1024];
+
+          if ((colon = strchr(start, ':')) != NULL)
+          {
+            strlcpy(user, start, (size_t)(colon - start + 1));
+            strlcpy(pass, colon + 1, sizeof(pass));
+          }
+          else
+          {
+            strlcpy(user, start, sizeof(user));
+            pass[0] = '\0';
+          }
+
+          *at = '@';		/* Restore @ */
+
+         /*
+          * Build the sanitized URI (slide host part over credentials)...
+          */
+
+          ulen = strlen(at + 1);
+          memmove(start, at + 1, ulen);
+          start[ulen] = '\0';
+
+         /*
+          * Store credentials in uadp.  Check if already stored to avoid churn.
+          */
+
+          snprintf(tpm_key, sizeof(tpm_key), "printer-cred/%s", printer->name);
+
+         /*
+          * Store credentials in uadp.  Compare the new credentials against
+          * any existing entry and only store when they differ (or are not
+          * yet stored), so that an updated SMB password is persisted while
+          * avoiding needless churn for unchanged data.
+          *
+          * Validate the printer name first: a name containing characters
+          * that are unsafe as a Uadp key (e.g. '/', '\', control bytes,
+          * spaces) is refused to prevent key injection or path-traversal-
+          * like collisions.  CUPS' validate_name() already blocks such
+          * characters at printer creation time; this is defense-in-depth.
+          */
+
+          if (!cupsd_uadp_safe_key_name(printer->name))
+          {
+            cupsdLogMessage(CUPSD_LOG_WARN,
+                            "Refusing to store SMB credentials in Uadp for printer \"%s\": "
+                            "name contains characters unsafe for a Uadp key.",
+                            printer->name);
+          }
+          else
+          {
+            cred_len = snprintf(cred_buf, sizeof(cred_buf), "%s\n%s", user, pass);
+
+            if (cupsd_uadp_retrieve(tpm_key, &tpm_data, &tpm_len) == 0 &&
+                tpm_data)
+            {
+              if (tpm_len != (size_t)cred_len ||
+                  memcmp(tpm_data, cred_buf, cred_len) != 0)
+              {
+                if (cupsd_uadp_store(tpm_key, (unsigned char *)cred_buf, cred_len))
+                  cupsdLogMessage(CUPSD_LOG_WARN,
+                                  "Unable to store SMB credentials in Uadp for printer %s.",
+                                  printer->name);
+              }
+
+              cupsd_uadp_free(tpm_data);
+            }
+            else
+            {
+              if (cupsd_uadp_store(tpm_key, (unsigned char *)cred_buf, cred_len))
+                cupsdLogMessage(CUPSD_LOG_WARN,
+                                "Unable to store SMB credentials in Uadp for printer %s.",
+                                printer->name);
+            }
+          }
+
+         /*
+          * Scrub the plaintext credentials from the stack before these
+          * buffers go out of scope, so they cannot leak via core dumps or
+          * /proc/<pid>/mem.
+          */
+
+          cupsd_uadp_scrub(cred_buf, sizeof(cred_buf));
+          cupsd_uadp_scrub(user, sizeof(user));
+          cupsd_uadp_scrub(pass, sizeof(pass));
+
+        }
+      }
+
+      /*
+       * Write the URI to printers.conf.  If credentials were embedded
+       * in the original URI they have been stripped from uri_buf and
+       * stored in Uadp; otherwise uri_buf holds the original URI.
+       */
+
+      cupsFilePutConf(fp, "DeviceURI", uri_buf);
+
+    }
+    else
+      cupsFilePutConf(fp, "DeviceURI", printer->device_uri);
 
     if (printer->port_monitor)
       cupsFilePutConf(fp, "PortMonitor", printer->port_monitor);
diff --git a/scheduler/uadp-secret.c b/scheduler/uadp-secret.c
new file mode 100644
index 000000000..60ffb461a
--- /dev/null
+++ b/scheduler/uadp-secret.c
@@ -0,0 +1,474 @@
+#include "cupsd.h"
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <errno.h>
+
+#ifdef HAVE_DBUS
+#  include <dbus/dbus.h>
+#endif /* HAVE_DBUS */
+
+
+/*
+ * Local constants...
+ */
+
+#define CUPS_UADP_DBUS_SERVICE		"com.deepin.daemon.Uadp"
+					/* D-Bus service name */
+#define CUPS_UADP_DBUS_PATH		"/com/deepin/daemon/Uadp"
+					/* D-Bus object path */
+#define CUPS_UADP_DBUS_INTERFACE	"com.deepin.daemon.Uadp"
+					/* D-Bus interface name */
+#define CUPS_UADP_DBUS_TIMEOUT		5000
+					/* D-Bus method call timeout (ms) */
+
+
+/*
+ * Local globals...
+ */
+
+#if defined(HAVE_DBUS)
+static DBusConnection	*uadp_con = NULL;
+				/* D-Bus system bus connection */
+#endif /* HAVE_DBUS */
+
+
+/*
+ * Local functions...
+ */
+
+#ifdef HAVE_DBUS
+static DBusConnection	*cupsd_uadp_get_connection(void);
+#endif /* HAVE_DBUS */
+
+
+/*
+ * 'cupsd_uadp_available()' - Check whether the Uadp service is available.
+ *
+ * Returns 1 if the D-Bus service responds, 0 otherwise.
+ */
+
+int					/* O - 1 if available, 0 otherwise */
+cupsd_uadp_available(void)
+{
+#ifdef HAVE_DBUS
+  DBusMessage	*message,		/* D-Bus method call */
+		*reply;			/* D-Bus reply */
+  DBusError	error;			/* D-Bus error */
+  dbus_bool_t	available = FALSE;	/* Service response */
+
+
+  if (!cupsd_uadp_get_connection())
+    return (0);
+
+  if ((message = dbus_message_new_method_call(CUPS_UADP_DBUS_SERVICE,
+                                               CUPS_UADP_DBUS_PATH,
+                                               CUPS_UADP_DBUS_INTERFACE,
+                                               "Available")) == NULL)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_available: Out of memory.");
+    return (0);
+  }
+
+  dbus_error_init(&error);
+
+  reply = dbus_connection_send_with_reply_and_block(uadp_con, message,
+                                                     CUPS_UADP_DBUS_TIMEOUT,
+                                                     &error);
+  dbus_message_unref(message);
+
+  if (!reply)
+  {
+    cupsdLogMessage(CUPSD_LOG_DEBUG,
+                    "cupsd_uadp_available: D-Bus call failed: %s: %s",
+                    error.name, error.message);
+    dbus_error_free(&error);
+    return (0);
+  }
+
+  /*
+   * Parse the reply (boolean)...
+   */
+
+  if (dbus_message_get_args(reply, &error,
+                             DBUS_TYPE_BOOLEAN, &available,
+                             DBUS_TYPE_INVALID))
+  {
+    dbus_message_unref(reply);
+    return (available != FALSE);
+  }
+
+  cupsdLogMessage(CUPSD_LOG_ERROR,
+                  "cupsd_uadp_available: Bad reply: %s: %s",
+                  error.name, error.message);
+  dbus_error_free(&error);
+  dbus_message_unref(reply);
+
+  return (0);
+
+#else
+  return (0);
+#endif /* HAVE_DBUS */
+}
+
+
+/*
+ * 'cupsd_uadp_store()' - Encrypt and store a secret via the Uadp service.
+ *
+ * The data is sent to the Uadp service for encryption and storage.
+ *
+ * Returns 0 on success, -1 on error.
+ */
+
+int					/* O - 0 on success, -1 on error */
+cupsd_uadp_store(
+    const char          *key,		/* I - Key name (e.g. "printer_password") */
+    const unsigned char *data,		/* I - Data to encrypt and store */
+    size_t              datalen)	/* I - Length of data */
+{
+#ifdef HAVE_DBUS
+  DBusMessage	*message,		/* D-Bus method call */
+		*reply;			/* D-Bus reply */
+  DBusError	error;			/* D-Bus error */
+  DBusMessageIter args, array;		/* Message iterators */
+
+
+  if (!key || !data || datalen == 0 ||
+      datalen > CUPS_UADP_MAX_SECRET_SIZE)
+    return (-1);
+
+  if (!cupsd_uadp_get_connection())
+    return (-1);
+
+  if ((message = dbus_message_new_method_call(CUPS_UADP_DBUS_SERVICE,
+                                               CUPS_UADP_DBUS_PATH,
+                                               CUPS_UADP_DBUS_INTERFACE,
+                                               "Set")) == NULL)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_store: Out of memory.");
+    return (-1);
+  }
+
+  /*
+   * Build arguments: (s name, ay data)...
+   */
+
+  dbus_message_iter_init_append(message, &args);
+  dbus_message_iter_append_basic(&args, DBUS_TYPE_STRING, &key);
+
+  dbus_message_iter_open_container(&args, DBUS_TYPE_ARRAY, "y", &array);
+  dbus_message_iter_append_fixed_array(&array, DBUS_TYPE_BYTE, &data, datalen);
+  dbus_message_iter_close_container(&args, &array);
+
+  dbus_error_init(&error);
+
+  reply = dbus_connection_send_with_reply_and_block(uadp_con, message,
+                                                     CUPS_UADP_DBUS_TIMEOUT,
+                                                     &error);
+  dbus_message_unref(message);
+
+  if (!reply)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_store: D-Bus call failed: %s: %s",
+                    error.name, error.message);
+    dbus_error_free(&error);
+    return (-1);
+  }
+
+  dbus_message_unref(reply);
+
+  cupsdLogMessage(CUPSD_LOG_INFO,
+                  "cupsd_uadp_store: Stored key \"%s\" (%u bytes).",
+                  key, (unsigned)datalen);
+
+  return (0);
+
+#else
+  (void)key;
+  (void)data;
+  (void)datalen;
+
+  return (-1);
+#endif /* HAVE_DBUS */
+}
+
+
+/*
+ * 'cupsd_uadp_retrieve()' - Retrieve and decrypt a secret via the Uadp service.
+ *
+ * The data buffer is allocated by this function and must be freed
+ * with @link cupsd_uadp_free@.
+ *
+ * Returns 0 on success, -1 on error.
+ */
+
+int					/* O - 0 on success, -1 on error */
+cupsd_uadp_retrieve(
+    const char          *key,		/* I - Key name */
+    unsigned char       **data,		/* O - Allocated decrypted data */
+    size_t              *datalen)	/* O - Length of data */
+{
+#ifdef HAVE_DBUS
+  DBusMessage	*message,		/* D-Bus method call */
+		*reply;			/* D-Bus reply */
+  DBusError	error;			/* D-Bus error */
+  DBusMessageIter args;			/* Iterator for arguments */
+  unsigned char	*raw_data = NULL;	/* Raw byte array from reply */
+  int		raw_len = 0;		/* Length of byte array */
+
+
+  if (!key || !data || !datalen)
+    return (-1);
+
+  *data    = NULL;
+  *datalen = 0;
+
+  if (!cupsd_uadp_get_connection())
+    return (-1);
+
+  if ((message = dbus_message_new_method_call(CUPS_UADP_DBUS_SERVICE,
+                                               CUPS_UADP_DBUS_PATH,
+                                               CUPS_UADP_DBUS_INTERFACE,
+                                               "Get")) == NULL)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_retrieve: Out of memory.");
+    return (-1);
+  }
+
+  dbus_message_iter_init_append(message, &args);
+  dbus_message_iter_append_basic(&args, DBUS_TYPE_STRING, &key);
+
+  dbus_error_init(&error);
+
+  reply = dbus_connection_send_with_reply_and_block(uadp_con, message,
+                                                     CUPS_UADP_DBUS_TIMEOUT,
+                                                     &error);
+  dbus_message_unref(message);
+
+  if (!reply)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_retrieve: D-Bus call failed: %s: %s",
+                    error.name, error.message);
+    dbus_error_free(&error);
+    return (-1);
+  }
+
+  /*
+   * Parse the reply: ay (byte array)...
+   */
+
+  if (dbus_message_get_args(reply, &error,
+                             DBUS_TYPE_ARRAY, DBUS_TYPE_BYTE, &raw_data, &raw_len,
+                             DBUS_TYPE_INVALID))
+  {
+    if (raw_len > 0 && raw_len <= (int)CUPS_UADP_MAX_SECRET_SIZE)
+    {
+      if ((*data = malloc((size_t)CUPS_UADP_MAX_SECRET_SIZE + 1)) != NULL)
+      {
+        memcpy(*data, raw_data, (size_t)raw_len);
+        *datalen = (size_t)raw_len;
+        (*data)[*datalen] = '\0';
+      }
+      else
+      {
+        cupsdLogMessage(CUPSD_LOG_ERROR,
+                        "cupsd_uadp_retrieve: Out of memory.");
+        dbus_message_unref(reply);
+        return (-1);
+      }
+    }
+
+    dbus_message_unref(reply);
+    return (0);
+  }
+
+  cupsdLogMessage(CUPSD_LOG_ERROR,
+                  "cupsd_uadp_retrieve: Bad reply: %s: %s",
+                  error.name, error.message);
+  dbus_error_free(&error);
+  dbus_message_unref(reply);
+
+  return (-1);
+
+#else
+  (void)key;
+  (void)data;
+  (void)datalen;
+
+  return (-1);
+#endif /* HAVE_DBUS */
+}
+
+
+/*
+ * 'cupsd_uadp_delete()' - Delete a stored secret via the Uadp service.
+ *
+ * Returns 0 on success, -1 on error (or if the secret does not exist).
+ */
+
+int					/* O - 0 on success, -1 on error */
+cupsd_uadp_delete(
+    const char *key)			/* I - Key name */
+{
+#ifdef HAVE_DBUS
+  DBusMessage	*message,		/* D-Bus method call */
+		*reply;			/* D-Bus reply */
+  DBusError	error;			/* D-Bus error */
+  DBusMessageIter args;			/* Iterator for arguments */
+
+
+  if (!key)
+    return (-1);
+
+  if (!cupsd_uadp_get_connection())
+    return (-1);
+
+  if ((message = dbus_message_new_method_call(CUPS_UADP_DBUS_SERVICE,
+                                               CUPS_UADP_DBUS_PATH,
+                                               CUPS_UADP_DBUS_INTERFACE,
+                                               "Delete")) == NULL)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_delete: Out of memory.");
+    return (-1);
+  }
+
+  dbus_message_iter_init_append(message, &args);
+  dbus_message_iter_append_basic(&args, DBUS_TYPE_STRING, &key);
+
+  dbus_error_init(&error);
+
+  reply = dbus_connection_send_with_reply_and_block(uadp_con, message,
+                                                     CUPS_UADP_DBUS_TIMEOUT,
+                                                     &error);
+  dbus_message_unref(message);
+
+  if (!reply)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_delete: D-Bus call failed: %s: %s",
+                    error.name, error.message);
+    dbus_error_free(&error);
+    return (-1);
+  }
+
+  dbus_message_unref(reply);
+
+  return (0);
+
+#else
+  (void)key;
+
+  return (-1);
+#endif /* HAVE_DBUS */
+}
+
+
+/*
+ * 'cupsd_uadp_free()' - Free a buffer allocated by cupsd_uadp_retrieve.
+ */
+
+void
+cupsd_uadp_free(unsigned char *data)	/* I - Buffer to free */
+{
+  if (data)
+  {
+    memset(data, 0, CUPS_UADP_MAX_SECRET_SIZE); /* Scrub before freeing */
+    free(data);
+  }
+}
+
+
+/*
+ * 'cupsd_uadp_scrub()' - Securely zeroize a buffer that held secret data.
+ *
+ * Writes through a volatile pointer so the stores cannot be optimized away
+ * as dead stores, which is critical when the buffer (e.g. plaintext
+ * credentials on the stack) is about to go out of scope.  Plain memset()
+ * would be elided by the compiler in that case, leaving the secret behind.
+ */
+
+void
+cupsd_uadp_scrub(void   *data,		/* I - Buffer to scrub */
+                 size_t datalen)	/* I - Size of buffer */
+{
+  volatile unsigned char	*p = (volatile unsigned char *)data;
+
+
+  if (!data || !datalen)
+    return;
+
+  while (datalen--)
+    *p++ = 0;
+}
+
+
+/*
+ * 'cupsd_uadp_safe_key_name()' - Validate a printer name as a Uadp key.
+ *
+ * Returns 1 if the name only contains characters that are safe to embed in
+ * a "printer-cred/<name>" Uadp key (letters, digits, '_', '-', '.'), and 0
+ * otherwise.  This blocks path-traversal and key-injection characters such
+ * as '/', '\', control bytes, and spaces.  Note that CUPS' own
+ * validate_name() already rejects '/' and control characters at printer
+ * creation time; this is a defense-in-depth check at the storage site.
+ */
+
+int					/* O - 1 if safe, 0 otherwise */
+cupsd_uadp_safe_key_name(const char *name)/* I - Name to check */
+{
+  const char	*ptr;			/* Pointer into name */
+
+
+  if (!name || !*name)
+    return (0);
+
+  for (ptr = name; *ptr; ptr ++)
+  {
+    unsigned char c = (unsigned char)*ptr;
+
+    if (!((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') ||
+          (c >= '0' && c <= '9') || c == '_' || c == '-' || c == '.'))
+      return (0);
+  }
+
+  return (1);
+}
+
+
+#ifdef HAVE_DBUS
+/*
+ * 'cupsd_uadp_get_connection()' - Get or create the D-Bus system bus connection.
+ *
+ * Returns the D-Bus connection, or NULL on failure.
+ */
+
+static DBusConnection *			/* O - D-Bus connection or NULL */
+cupsd_uadp_get_connection(void)
+{
+  DBusError	error;			/* D-Bus error */
+
+
+  if (uadp_con)
+    return (uadp_con);
+
+  dbus_error_init(&error);
+
+  if ((uadp_con = dbus_bus_get(DBUS_BUS_SYSTEM, &error)) == NULL)
+  {
+    cupsdLogMessage(CUPSD_LOG_ERROR,
+                    "cupsd_uadp_get_connection: Unable to connect to "
+                    "system bus: %s: %s",
+                    error.name, error.message);
+    dbus_error_free(&error);
+    return (NULL);
+  }
+
+  return (uadp_con);
+}
+#endif /* HAVE_DBUS */
